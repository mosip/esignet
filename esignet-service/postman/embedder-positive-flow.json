{
  "info": {
    "name": "eSignet — positive flows",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "eSignet embedder (github.com/mosip/esignet) at {{baseUrl}}.\n\nImport embedder-local.environment.json. Start the server with ISSUER_URL matching baseUrl (e.g. http://127.0.0.1:8080).\n\nRun folder **0** once, then **1** (app-native), **2** (full OAuth + userinfo), or **3** (MOSIP OTP + OAuth) in order.\n\nFolder **3** requires AUTHN_PROVIDER=mosip and MOSIP_* env vars (see .env.example). Set individualId and otp in the Postman environment before running."
  },
  "item": [
    {
      "name": "0 — Shared setup",
      "item": [
        {
          "name": "Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('health ok', () => pm.response.to.have.status(200));",
                  "pm.test('body ok', () => pm.response.text().includes('ok'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "OIDC discovery",
          "request": { "method": "GET", "url": "{{baseUrl}}/.well-known/openid-configuration" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('discovery 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const base = pm.environment.get('baseUrl').replace(/\\/$/, '');",
                  "pm.test('issuer matches baseUrl', () => pm.expect(j.issuer.replace(/\\/$/, '')).to.eql(base));",
                  "pm.test('authorization_endpoint', () => pm.expect(j.authorization_endpoint).to.be.a('string'));",
                  "pm.test('token_endpoint', () => pm.expect(j.token_endpoint).to.be.a('string'));",
                  "pm.test('userinfo_endpoint', () => pm.expect(j.userinfo_endpoint).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow meta (APP)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/flow/meta?type=APP&id={{applicationId}}&language=en&namespace=auth",
              "host": ["{{baseUrl}}"],
              "path": ["flow", "meta"],
              "query": [
                { "key": "type", "value": "APP" },
                { "key": "id", "value": "{{applicationId}}" },
                { "key": "language", "value": "en" },
                { "key": "namespace", "value": "auth" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('flow meta APP', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow meta (OU)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/flow/meta?type=OU&id={{ouId}}",
              "host": ["{{baseUrl}}"],
              "path": ["flow", "meta"],
              "query": [
                { "key": "type", "value": "OU" },
                { "key": "id", "value": "{{ouId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('flow meta OU', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1 — App-native flow/execute",
      "item": [
        {
          "name": "Flow execute — start",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": \"{{applicationId}}\",\n  \"flowType\": \"AUTHENTICATION\"\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('start 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('INCOMPLETE', () => pm.expect(j.flowStatus).to.eql('INCOMPLETE'));",
                  "pm.environment.set('executionId', j.executionId);",
                  "pm.environment.set('challengeToken', j.challengeToken);",
                  "if (j.data && j.data.actions && j.data.actions[0]) {",
                  "  pm.environment.set('actionRef', j.data.actions[0].ref);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\",\n  \"challengeToken\": \"{{challengeToken}}\",\n  \"action\": \"{{actionRef}}\",\n  \"inputs\": {\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('credentials 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('COMPLETE', () => pm.expect(j.flowStatus).to.eql('COMPLETE'));",
                  "pm.test('assertion', () => pm.expect(j.assertion).to.be.a('string').and.not.empty);",
                  "pm.environment.set('assertion', j.assertion);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2 — Full OAuth (PKCE)",
      "item": [
        {
          "name": "PKCE setup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function base64UrlEncode(buffer) {",
                  "  return btoa(String.fromCharCode(...new Uint8Array(buffer)))",
                  "    .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
                  "}",
                  "const array = new Uint8Array(32);",
                  "crypto.getRandomValues(array);",
                  "const codeVerifier = base64UrlEncode(array);",
                  "pm.environment.set('codeVerifier', codeVerifier);",
                  "return crypto.subtle.digest('SHA-256', new TextEncoder().encode(codeVerifier))",
                  "  .then(hash => {",
                  "    pm.environment.set('codeChallenge', base64UrlEncode(hash));",
                  "  });"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('codeVerifier set', () => pm.expect(pm.environment.get('codeVerifier')).to.be.a('string').and.not.empty);",
                  "pm.test('codeChallenge set', () => pm.expect(pm.environment.get('codeChallenge')).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Authorize (no redirect)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/oauth2/authorize?client_id={{clientId}}&redirect_uri={{redirectUri}}&response_type=code&scope={{scope}}&state=esignet-test&code_challenge={{codeChallenge}}&code_challenge_method=S256",
              "host": ["{{baseUrl}}"],
              "path": ["oauth2", "authorize"],
              "query": [
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "redirect_uri", "value": "{{redirectUri}}" },
                { "key": "response_type", "value": "code" },
                { "key": "scope", "value": "{{scope}}" },
                { "key": "state", "value": "esignet-test" },
                { "key": "code_challenge", "value": "{{codeChallenge}}" },
                { "key": "code_challenge_method", "value": "S256" }
              ]
            }
          },
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('authorize 302', () => pm.response.to.have.status(302));",
                  "const location = pm.response.headers.get('Location');",
                  "pm.test('Location present', () => pm.expect(location).to.be.a('string').and.not.empty);",
                  "const redirectUrl = new URL(location, pm.environment.get('baseUrl'));",
                  "pm.test('authId present', () => pm.expect(redirectUrl.searchParams.get('authId')).to.be.a('string').and.not.empty);",
                  "pm.test('executionId present', () => pm.expect(redirectUrl.searchParams.get('executionId')).to.be.a('string').and.not.empty);",
                  "pm.environment.set('authId', redirectUrl.searchParams.get('authId'));",
                  "pm.environment.set('executionId', redirectUrl.searchParams.get('executionId'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\"\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('resume 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('challengeToken', () => pm.expect(j.challengeToken).to.be.a('string').and.not.empty);",
                  "pm.environment.set('challengeToken', j.challengeToken);",
                  "if (j.data && j.data.actions && j.data.actions[0]) {",
                  "  pm.environment.set('actionRef', j.data.actions[0].ref);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\",\n  \"challengeToken\": \"{{challengeToken}}\",\n  \"action\": \"{{actionRef}}\",\n  \"inputs\": {\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('credentials 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('COMPLETE', () => pm.expect(j.flowStatus).to.eql('COMPLETE'));",
                  "pm.test('assertion', () => pm.expect(j.assertion).to.be.a('string').and.not.empty);",
                  "pm.environment.set('assertion', j.assertion);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Auth callback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authId\": \"{{authId}}\",\n  \"assertion\": \"{{assertion}}\"\n}"
            },
            "url": "{{baseUrl}}/oauth2/auth/callback"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('callback 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const ru = j.redirect_uri || j.redirectUri;",
                  "pm.test('redirect_uri present', () => pm.expect(ru).to.be.a('string').and.not.empty);",
                  "const url = new URL(ru);",
                  "pm.test('no OAuth error in redirect', () => pm.expect(url.searchParams.get('error')).to.be.null);",
                  "pm.test('authorization code present', () => pm.expect(url.searchParams.get('code')).to.be.a('string').and.not.empty);",
                  "pm.environment.set('authCode', url.searchParams.get('code'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "code", "value": "{{authCode}}" },
                { "key": "redirect_uri", "value": "{{redirectUri}}" },
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "code_verifier", "value": "{{codeVerifier}}" }
              ]
            },
            "url": "{{baseUrl}}/oauth2/token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('token 200', () => pm.response.to.have.status(200));",
                  "const t = pm.response.json();",
                  "pm.test('access_token', () => pm.expect(t.access_token).to.be.a('string').and.not.empty);",
                  "pm.test('id_token', () => pm.expect(t.id_token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('accessToken', t.access_token);",
                  "pm.environment.set('idToken', t.id_token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "UserInfo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/oauth2/userinfo"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('userinfo 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('sub claim', () => pm.expect(j.sub).to.be.a('string').and.not.empty);",
                  "pm.test('sub matches username', () => pm.expect(j.sub).to.eql(pm.environment.get('username')));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3 — MOSIP OTP flow",
      "item": [
        {
          "name": "PKCE setup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function base64UrlEncode(buffer) {",
                  "  return btoa(String.fromCharCode(...new Uint8Array(buffer)))",
                  "    .replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=/g, '');",
                  "}",
                  "const array = new Uint8Array(32);",
                  "crypto.getRandomValues(array);",
                  "const codeVerifier = base64UrlEncode(array);",
                  "pm.environment.set('codeVerifier', codeVerifier);",
                  "return crypto.subtle.digest('SHA-256', new TextEncoder().encode(codeVerifier))",
                  "  .then(hash => {",
                  "    pm.environment.set('codeChallenge', base64UrlEncode(hash));",
                  "  });"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('codeVerifier set', () => pm.expect(pm.environment.get('codeVerifier')).to.be.a('string').and.not.empty);",
                  "pm.test('codeChallenge set', () => pm.expect(pm.environment.get('codeChallenge')).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Authorize (no redirect)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/oauth2/authorize?client_id={{otpClientId}}&redirect_uri={{redirectUri}}&response_type=code&scope={{scope}}&state=esignet-otp-test&code_challenge={{codeChallenge}}&code_challenge_method=S256",
              "host": ["{{baseUrl}}"],
              "path": ["oauth2", "authorize"],
              "query": [
                { "key": "client_id", "value": "{{otpClientId}}" },
                { "key": "redirect_uri", "value": "{{redirectUri}}" },
                { "key": "response_type", "value": "code" },
                { "key": "scope", "value": "{{scope}}" },
                { "key": "state", "value": "esignet-otp-test" },
                { "key": "code_challenge", "value": "{{codeChallenge}}" },
                { "key": "code_challenge_method", "value": "S256" }
              ]
            }
          },
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('authorize 302', () => pm.response.to.have.status(302));",
                  "const location = pm.response.headers.get('Location');",
                  "pm.test('Location present', () => pm.expect(location).to.be.a('string').and.not.empty);",
                  "const redirectUrl = new URL(location, pm.environment.get('baseUrl'));",
                  "pm.test('authId present', () => pm.expect(redirectUrl.searchParams.get('authId')).to.be.a('string').and.not.empty);",
                  "pm.test('executionId present', () => pm.expect(redirectUrl.searchParams.get('executionId')).to.be.a('string').and.not.empty);",
                  "pm.environment.set('authId', redirectUrl.searchParams.get('authId'));",
                  "pm.environment.set('executionId', redirectUrl.searchParams.get('executionId'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow meta (OTP app)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/flow/meta?type=APP&id={{otpApplicationId}}&language=en&namespace=auth",
              "host": ["{{baseUrl}}"],
              "path": ["flow", "meta"],
              "query": [
                { "key": "type", "value": "APP" },
                { "key": "id", "value": "{{otpApplicationId}}" },
                { "key": "language", "value": "en" },
                { "key": "namespace", "value": "auth" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('flow meta OTP app', () => pm.response.to.have.status(200));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — resume",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\"\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('resume 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('INCOMPLETE', () => pm.expect(j.flowStatus).to.eql('INCOMPLETE'));",
                  "pm.test('username prompt', () => {",
                  "  const ids = (j.data && j.data.inputs || []).map(i => i.identifier);",
                  "  pm.expect(ids).to.include('username');",
                  "});",
                  "pm.test('challengeToken', () => pm.expect(j.challengeToken).to.be.a('string').and.not.empty);",
                  "pm.environment.set('challengeToken', j.challengeToken);",
                  "if (j.data && j.data.actions && j.data.actions[0]) {",
                  "  pm.environment.set('actionRef', j.data.actions[0].ref);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — individual ID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\",\n  \"challengeToken\": \"{{challengeToken}}\",\n  \"action\": \"{{actionRef}}\",\n  \"inputs\": {\n    \"username\": \"{{individualId}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get('individualId')) {",
                  "  throw new Error('Set individualId in the environment (MOSIP UIN) before running this folder.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('individual ID 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('INCOMPLETE', () => pm.expect(j.flowStatus).to.eql('INCOMPLETE'));",
                  "pm.test('otp prompt', () => {",
                  "  const ids = (j.data && j.data.inputs || []).map(i => i.identifier);",
                  "  pm.expect(ids).to.include('otp');",
                  "});",
                  "if (j.challengeToken) pm.environment.set('challengeToken', j.challengeToken);",
                  "if (j.data && j.data.actions && j.data.actions[0]) {",
                  "  pm.environment.set('actionRef', j.data.actions[0].ref);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\",\n  \"challengeToken\": \"{{challengeToken}}\",\n  \"action\": \"{{actionRef}}\",\n  \"inputs\": {\n    \"otp\": \"{{otp}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.environment.get('otp')) {",
                  "  throw new Error('Set otp in the environment after MOSIP sends the code.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('otp submit 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "if (j.challengeToken) pm.environment.set('challengeToken', j.challengeToken);",
                  "if (j.flowStatus === 'COMPLETE') {",
                  "  pm.test('assertion', () => pm.expect(j.assertion).to.be.a('string').and.not.empty);",
                  "  pm.environment.set('assertion', j.assertion);",
                  "} else {",
                  "  pm.test('INCOMPLETE after OTP', () => pm.expect(j.flowStatus).to.eql('INCOMPLETE'));",
                  "  if (j.data && j.data.actions && j.data.actions[0]) {",
                  "    pm.environment.set('actionRef', j.data.actions[0].ref);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Flow execute — credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"executionId\": \"{{executionId}}\",\n  \"challengeToken\": \"{{challengeToken}}\",\n  \"action\": \"{{actionRef}}\",\n  \"inputs\": {\n    \"username\": \"{{individualId}}\",\n    \"otp\": \"{{otp}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/flow/execute"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('credentials 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('COMPLETE', () => pm.expect(j.flowStatus).to.eql('COMPLETE'));",
                  "pm.test('assertion', () => pm.expect(j.assertion).to.be.a('string').and.not.empty);",
                  "pm.environment.set('assertion', j.assertion);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Auth callback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authId\": \"{{authId}}\",\n  \"assertion\": \"{{assertion}}\"\n}"
            },
            "url": "{{baseUrl}}/oauth2/auth/callback"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('callback 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const ru = j.redirect_uri || j.redirectUri;",
                  "pm.test('redirect_uri present', () => pm.expect(ru).to.be.a('string').and.not.empty);",
                  "const url = new URL(ru);",
                  "pm.test('no OAuth error in redirect', () => pm.expect(url.searchParams.get('error')).to.be.null);",
                  "pm.test('authorization code present', () => pm.expect(url.searchParams.get('code')).to.be.a('string').and.not.empty);",
                  "pm.environment.set('authCode', url.searchParams.get('code'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "code", "value": "{{authCode}}" },
                { "key": "redirect_uri", "value": "{{redirectUri}}" },
                { "key": "client_id", "value": "{{otpClientId}}" },
                { "key": "code_verifier", "value": "{{codeVerifier}}" }
              ]
            },
            "url": "{{baseUrl}}/oauth2/token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('token 200', () => pm.response.to.have.status(200));",
                  "const t = pm.response.json();",
                  "pm.test('access_token', () => pm.expect(t.access_token).to.be.a('string').and.not.empty);",
                  "pm.test('id_token', () => pm.expect(t.id_token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('accessToken', t.access_token);",
                  "pm.environment.set('idToken', t.id_token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "UserInfo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/oauth2/userinfo"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('userinfo 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('sub claim', () => pm.expect(j.sub).to.be.a('string').and.not.empty);",
                  "pm.test('sub matches individualId', () => pm.expect(j.sub).to.eql(pm.environment.get('individualId')));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
