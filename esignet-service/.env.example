# ─────────────────────────────────────────────────────────────────────────────
# esignet-service environment variables
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# The Makefile automatically loads .env when present.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP / ThunderID engine ───────────────────────────────────────────────────
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
PORT=8080
ISSUER_URL=http://127.0.0.1:8080
DATA_DIR=./data
SIGNING_KEY_PATH=./keys/signing.key

# Optional JWT/OAuth engine overrides (unset = Thunder defaults)
# JWT_AUDIENCE=
# JWT_PREFERRED_KEY_ID=
# JWT_LEEWAY=
# JWKS_CACHE_TTL=
# OAUTH_AUTH_CODE_LIFETIME_SECONDS=
# OAUTH_ACCESS_TOKEN_LIFETIME_SECONDS=
# OAUTH_REFRESH_TOKEN_LIFETIME_SECONDS=
# OAUTH_PAR_EXPIRY_SECONDS=
# OAUTH_PAR_REQUIRED=false
# OAUTH_DPOP_REQUIRED=false
# OAUTH_REFRESH_TOKEN_RENEW_ON_GRANT=false

# Login gate redirects for /oauth2/authorize
GATE_CLIENT_SCHEME=http
GATE_CLIENT_HOSTNAME=127.0.0.1
GATE_CLIENT_PORT=8080
GATE_CLIENT_LOGIN_PATH=/signin
GATE_CLIENT_ERROR_PATH=/error

# Used by `make smoke` (defaults to ISSUER_URL when unset)
# BASE_URL=http://127.0.0.1:8080

# ── PostgreSQL (client management persistence) ────────────────────────────────
# Option A: full DSN (takes precedence over individual vars)
# POSTGRES_URL=postgres://esignet:secret@localhost:5432/esignet?sslmode=disable

# Option B: individual connection params
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mosip_esignet
POSTGRES_USER=esignet
POSTGRES_PASSWORD=secret

# Connection pool tuning (optional — defaults shown)
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME_SECS=300
# DB_CONN_MAX_IDLE_TIME_SECS=60

# ── Redis (runtime / session store) ──────────────────────────────────────────
# Option A: full DSN  redis://[:password@]host:port/db  or  rediss:// for TLS
# REDIS_URL=redis://:secret@localhost:6379/0

# Option B: individual connection params
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=secret
REDIS_DB=0

# TLS (automatically enabled for rediss:// URLs)
# REDIS_TLS_ENABLED=false

# Sentinel HA mode (set both to enable; takes precedence over single-node params)
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_ADDRS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Connection pool tuning (optional — defaults shown)
# REDIS_POOL_SIZE=10
# REDIS_MIN_IDLE_CONNS=2
# REDIS_CONN_MAX_IDLE_TIME_SECS=300
# REDIS_CONN_MAX_LIFETIME_SECS=0

# Per-operation timeouts in seconds (optional — defaults shown)
# REDIS_DIAL_TIMEOUT_SECS=5
# REDIS_READ_TIMEOUT_SECS=3
# REDIS_WRITE_TIMEOUT_SECS=3

# Key namespace prefix — stored as <prefix><type>:<id> (e.g. esignet:flow:<id>)
# REDIS_KEY_PREFIX=esignet:

# ── Client management API ─────────────────────────────────────────────────────
# Bearer scope required to call /client-mgmt/* endpoints
# CLIENT_MGMT_REQUIRED_SCOPE=client_mgmt

# JWKS endpoint for validating Bearer tokens on client-mgmt endpoints.
# Defaults to <ISSUER_URL>/.well-known/jwks.json
# CLIENT_MGMT_JWKS_ENDPOINT=http://127.0.0.1:8080/.well-known/jwks.json

# How long fetched JWKS keys are cached before re-fetching (seconds)
# CLIENT_MGMT_JWKS_CACHE_TTL_SECS=300

# ── Authentication provider ───────────────────────────────────────────────────
# Authentication provider: catalog (local users) or mosip (MOSIP IDA)
AUTHN_PROVIDER=catalog

# ── MOSIP IDA authentication ──────────────────────────────────────────────────
# Common API host; endpoint URLs are derived from this and MOSIP_LICENSE_KEY
# unless overridden individually below.
MOSIP_API_BASE_URL=https://api-internal.test.mosip.net
MOSIP_LICENSE_KEY=sample-license-key

# IDA request metadata (domainUri defaults to MOSIP_API_BASE_URL; env defaults to Staging)
# MOSIP_DOMAIN_URI=https://api-internal.test.mosip.net
# MOSIP_ENV=Staging

# Optional full URL overrides (leave commented to use MOSIP_API_BASE_URL defaults)
# MOSIP_IDA_PARTNER_CERT_URL=https://api-internal.test.mosip.net/mosip-certs/ida-partner.cer
# MOSIP_SEND_OTP_BASE_URL=https://api-internal.test.mosip.net/idauthentication/v1/otp/<license-key>/
# MOSIP_KYC_AUTH_BASE_URL=https://api-internal.test.mosip.net/idauthentication/v1/kyc-auth/delegated/<license-key>/
# MOSIP_KYC_EXCHANGE_BASE_URL=https://api-internal.test.mosip.net/idauthentication/v1/kyc-exchange/delegated/<license-key>/

# Partner keystore for request signing (required for MOSIP auth flows)
MOSIP_P12_PATH=./sample-partner-keystore.p12
MOSIP_P12_PASSWORD=add-p12-password-here
