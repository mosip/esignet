# ─────────────────────────────────────────────────────────────────────────────
# esignet-service environment variables
#
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
#
# make.sh loads .env automatically when present.
# Precedence: VAR=VALUE on the command line > .env > shell environment > defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP / ThunderID engine ───────────────────────────────────────────────────
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Listen port (code default: 8088; make.sh defaults to 8080)
PORT=8080

# OIDC issuer, JWT iss claim, and discovery base URL
MOSIP_ESIGNET_HOST=http://127.0.0.1:8080

# Declarative YAML root (fixtures under data/config/resources/)
DATA_DIR=./data

# 64-char hex key for Thunder crypto.encryption.key in data/deployment.yaml
# Generate with: openssl rand -hex 32
# CRYPTO_ENCRYPTION_KEY=<unique-64-char-hex>

# Signing material is generated by `./make.sh keys` at keys/signing.key + signing.crt

# Optional JWT/OAuth engine overrides (unset = Thunder defaults)
# JWT_AUDIENCE=
# JWT_PREFERRED_KEY_ID=
# OAUTH_AUTH_CODE_LIFETIME_SECONDS=120
# OAUTH_ACCESS_TOKEN_LIFETIME_SECONDS=3600
# OAUTH_PAR_EXPIRY_SECONDS=3600

# Login gate redirects for /oauth2/authorize (Thunder gate client)
OIDC_UI_SCHEME=http
OIDC_UI_HOSTNAME=127.0.0.1
OIDC_UI_PORT=3000
OIDC_UI_LOGIN_PATH=/signin
OIDC_UI_ERROR_PATH=/error

# Optional declarative defaults (flow/theme/layout selection)
# DEFAULT_THEME_ID=
# DEFAULT_LAYOUT_ID=
# DEFAULT_AUTH_FLOW_ID=
# DEFAULT_REGISTRATION_FLOW_ID=
# DEFAULT_RECOVERY_FLOW_ID=

# Used by `make smoke` (defaults to MOSIP_ESIGNET_HOST when unset)
# BASE_URL=http://127.0.0.1:8080

# ── PostgreSQL (client management persistence) ────────────────────────────────
# Option A: full DSN (takes precedence over individual vars)
# POSTGRES_URL=postgres://esignet:secret@localhost:5432/mosip_esignet?sslmode=disable

# Option B: individual connection params
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mosip_esignet
DATABASE_USERNAME=esignet
# DB_DBUSER_PASSWORD=secret

# Connection pool tuning (optional — defaults shown)
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME_SECS=300
# DB_CONN_MAX_IDLE_TIME_SECS=60

# ── Redis (runtime / session store) ──────────────────────────────────────────
# Option A: full DSN  redis://[:password@]host:port/db  or  rediss:// for TLS
# REDIS_URL=redis://:secret@localhost:6379/0

# Option B: individual connection params
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=secret
REDIS_DB=0

# TLS (automatically enabled for rediss:// URLs)
# REDIS_TLS_ENABLED=false

# Sentinel HA mode (set both to enable; takes precedence over single-node params)
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_SENTINEL_ADDRS=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Connection pool tuning (optional — defaults shown)
# REDIS_POOL_SIZE=10
# REDIS_MIN_IDLE_CONNS=2
# REDIS_CONN_MAX_IDLE_TIME_SECS=300
# REDIS_CONN_MAX_LIFETIME_SECS=0

# Per-operation timeouts in seconds (optional — defaults shown)
# REDIS_DIAL_TIMEOUT_SECS=5
# REDIS_READ_TIMEOUT_SECS=3
# REDIS_WRITE_TIMEOUT_SECS=3

# Key namespace prefix — stored as <prefix><type>:<id> (e.g. esignet:flow:<id>)
# REDIS_KEY_PREFIX=esignet:

# ── Client management API ─────────────────────────────────────────────────────
# Bearer scope required to call /client-mgmt/* endpoints
# CLIENT_MGMT_REQUIRED_SCOPE=client_mgmt

# Expected iss claim and JWKS URL for validating Bearer tokens on client-mgmt endpoints.
# Set both to match MOSIP_ESIGNET_HOST when using the local engine JWKS.
# CLIENT_MGMT_ISSUER_URL=http://127.0.0.1:8080
# CLIENT_MGMT_JWKS_ENDPOINT=http://127.0.0.1:8080/.well-known/jwks.json

# How long fetched JWKS keys are cached before re-fetching (seconds)
# CLIENT_MGMT_JWKS_CACHE_TTL_SECS=300

# ── Authentication provider ───────────────────────────────────────────────────
# Authentication provider: mosip (MOSIP IDA) or sunbird (SunbirdRC registry KBI) or mock (mock authentication)
AUTHN_PROVIDER=mock

# ── Mock authentication (used only when AUTHN_PROVIDER=mock) ─────────────────
# The mock provider is a thin HTTP client to a running mock-identity-system
# instance (https://github.com/mosip/esignet-mock-services); it does not validate
# credentials or store identities itself. Endpoint URLs default from this domain
# unless overridden individually below.
# MOSIP_ESIGNET_MOCK_DOMAIN_URL=http://mock-identity-system.mockid

# Optional full URL overrides (leave commented to use MOSIP_ESIGNET_MOCK_DOMAIN_URL defaults)
# MOSIP_ESIGNET_MOCK_KYC_AUTH_URL=http://mock-identity-system.mockid/v1/mock-identity-system/v2/kyc-auth
# MOSIP_ESIGNET_MOCK_KYC_EXCHANGE_URL=http://mock-identity-system.mockid/v1/mock-identity-system/kyc-exchange
# MOSIP_ESIGNET_MOCK_KYC_EXCHANGE_V3_URL=http://mock-identity-system.mockid/v1/mock-identity-system/v3/kyc-exchange
# MOSIP_ESIGNET_MOCK_SEND_OTP_URL=http://mock-identity-system.mockid/v1/mock-identity-system/send-otp

# ── MOSIP ──────────────────────────────────────────────────

# ── IDA authentication ─────────────────────────
# Internal API host; IDA endpoint URLs are derived from this and MOSIP_ESIGNET_MISP_KEY
# unless overridden individually below.
MOSIP_API_INTERNAL_HOST=https://api-internal.test.mosip.net
MOSIP_ESIGNET_MISP_KEY=sample-license-key

# IDA request metadata (domainUri defaults to MOSIP_API_INTERNAL_HOST; env defaults to Staging)
# MOSIP_ESIGNET_DOMAIN_URL=https://api-internal.test.mosip.net
# IDA_AUTHENTICATOR_ENV=Staging

# Optional full URL overrides (leave commented to use MOSIP_API_INTERNAL_HOST defaults)
# MOSIP_ESIGNET_AUTHENTICATOR_IDA_CERT_URL=https://api-internal.test.mosip.net/mosip-certs/ida-partner.cer
# MOSIP_ESIGNET_AUTHENTICATOR_IDA_SEND_OTP_URL=https://api-internal.test.mosip.net/idauthentication/v1/otp/<license-key>/
# MOSIP_ESIGNET_AUTHENTICATOR_IDA_KYC_AUTH_URL=https://api-internal.test.mosip.net/idauthentication/v1/kyc-auth/delegated/<license-key>/
# MOSIP_ESIGNET_AUTHENTICATOR_IDA_KYC_EXCHANGE_URL=https://api-internal.test.mosip.net/idauthentication/v1/kyc-exchange/delegated/<license-key>/

# Partner keystore for request signing (required for MOSIP auth flows)
MOSIP_P12_PATH=./sample-partner-keystore.p12
MOSIP_P12_PASSWORD=add-p12-password-here

# ── Observability / audit publishing ───────────────────────
# The observability backend is selected by AUTHN_PROVIDER (see above), not a
# separate setting:
#   mosip         publish flow lifecycle events to mosip-audit-manager (see below)
#   anything else log event details via the application logger

# Flow lifecycle events are published to mosip-audit-manager when
# AUTHN_PROVIDER=mosip and an audit endpoint is configured. URLs default from
# MOSIP_API_INTERNAL_HOST unless set here.
# Auth: a token is fetched from authmanager (clientId/secretKey/appId) and sent
# to the audit endpoint as Cookie "Authorization=<token>". When the secret is
# unset, audits are posted without the Authorization cookie.
# MOSIP_ESIGNET_AUDIT_MANAGER_URL=https://api-internal.test.mosip.net/v1/auditmanager/audits
# MOSIP_ESIGNET_AUTH_TOKEN_URL=https://api-internal.test.mosip.net/v1/authmanager/authenticate/clientidsecretkey
# MOSIP_ESIGNET_IDA_CLIENT_ID=mosip-ida-client
# MOSIP_ESIGNET_IDA_CLIENT_SECRET=
# MOSIP_ESIGNET_IDA_APP_ID=ida

# ── SunbirdRC KBI authentication ──────────────────────────────────────────────
# Knowledge-based-identity auth against a SunbirdRC registry. Enabled when
# AUTHN_PROVIDER=sunbird. The search URL is required.
#
# Registry search endpoint (required; ...auth-factor.kbi.registry-search-url).
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_AUTH_FACTOR_KBI_REGISTRY_SEARCH_URL=https://registry.dev1.mosip.net/api/v1/Insurance/search
#
# Registry entity (get) endpoint used to fetch attributes (...registry-get-url).
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_REGISTRY_GET_URL=https://registry.dev1.mosip.net/api/v1/Insurance/
#
# Registry field that the entered individualId maps to in the search filter
# (...auth-factor.kbi.individual-id-field). Default: policyNumber.
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_AUTH_FACTOR_KBI_INDIVIDUAL_ID_FIELD=policyNumber
#
# Registry field holding the entity id returned by search (...kbi.entity-id-field). Default: osid.
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_KBI_ENTITY_ID_FIELD=osid
#
# KBI fields collected from the user (JSON array; ...auth-factor.kbi.field-details).
# The individual-id-field entry is the identifier; every other entry is a required credential.
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_AUTH_FACTOR_KBI_FIELD_DETAILS=[{"id":"policyNumber","type":"text","format":""},{"id":"fullName","type":"text","format":""},{"id":"dob","type":"date","format":"dd/mm/yyyy"}]
#
# OIDC claim -> registry field map (JSON; ...identity-openid-claims-mapping). Empty/unset or malformed = no claims released (fail closed).
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_IDENTITY_OPENID_CLAIMS_MAPPING={"name":"fullName","email":"email","phone_number":"mobile","gender":"gender","birthdate":"dob"}
#
# HTTP timeout in seconds. Default 10.
# MOSIP_ESIGNET_AUTHENTICATOR_SUNBIRD_RC_REQUEST_TIMEOUT_SECS=10
